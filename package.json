{
  "name": "agent-autokit",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter '*' build",
    "test": "bun test",
    "lint": "biome check . && eslint .",
    "format": "biome format --write .",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@cattyneo/autokit-core": "workspace:*",
    "@cattyneo/autokit-tui": "workspace:*"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/node": "^25.6.0",
    "eslint": "^10.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1"
  }
}
