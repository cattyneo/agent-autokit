{
  "name": "agent-autokit",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b && bun run --cwd packages/cli build",
    "test": "bun test",
    "lint": "biome check . && eslint .",
    "format": "biome format --write .",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@cattyneo/autokit-claude-runner": "workspace:*",
    "@cattyneo/autokit-core": "workspace:*",
    "@cattyneo/autokit-codex-runner": "workspace:*",
    "@cattyneo/autokit-serve": "workspace:*",
    "@cattyneo/autokit-workflows": "workspace:*",
    "@cattyneo/autokit-tui": "workspace:*"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/node": "^25.6.0",
    "eslint": "^10.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "yaml": "^2.8.4"
  }
}
